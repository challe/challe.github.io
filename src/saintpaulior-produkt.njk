---
layout: base.njk
pagination:
  data: products.products
  size: 1
  alias: product
  addAllPagesToCollections: true
permalink: "saintpaulior/{{ product.title | slugify }}/"
eleventyComputed:
  title: "{{ product.title }} - Saintpaulia-stickling i Hudiksvall"
  description: "{{ product.description }} Köp stickling av {{ product.title }} hos Drumla i Rogsta, Hudiksvall. Handodlad krukväxt."
  keywords: "{{ product.title }}, Saintpaulia, stickling, krukväxt, köpa blommor Hudiksvall, köpa växter Hudiksvall, Drumla, Rogsta"
  ogDescription: "{{ product.description }} Köp stickling av {{ product.title }} hos Drumla i Rogsta, Hudiksvall."
  ogImage: "/{{ product.imagePath }}"
---

{% set price = site.pricing[product.category].price or site.pricing.standard.price %}
{% set categoryLabel = product.category | capitalize %}
{% set categoryIcon = site.pricing[product.category].icon %}

{% block styles %}
<style>
  .product-image-wrap {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 0.5rem;
  }
  .product-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
{% endblock %}

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title }}",
  "description": "{{ product.description }}",
  "image": "{{ site.url }}/{{ product.imagePath }}",
  "url": "{{ site.url }}/saintpaulior/{{ product.title | slugify }}/",
  "sku": "SP-{{ product.number or loop.index }}",
  "category": "Krukväxter > Saintpaulia",
  "brand": {
    "@type": "Brand",
    "name": "{{ site.business.name }}"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "SEK",
    "price": "{{ price }}",
    "itemCondition": "https://schema.org/NewCondition",
    "availability": "https://schema.org/InStock",
    "url": "{{ site.url }}/saintpaulior/{{ product.title | slugify }}/",
    "seller": {
      "@id": "https://drumla.se/#business"
    },
    "priceValidUntil": "2026-12-31"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": "3",
    "bestRating": "5",
    "worstRating": "1"
  }
}
</script>
{% endblock %}

<!-- Hero -->
<section class="header-area header-eight">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-12 col-md-12 col-12">
        <div class="header-content text-center">
          <h1>{{ product.title }}</h1>
          <p>Saintpaulia-stickling i Hudiksvall</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% set breadcrumbs = [
  { name: "Hem", url: "/", current: false },
  { name: "Saintpaulior", url: "/saintpaulior/", current: false },
  { name: product.title, url: page.url, current: true }
] %}
{% set breadcrumbsColor = 'bg-white' %}
{% set breadcrumbsWidth = 'col-lg-12' %}
{% include "breadcrumbs.njk" %}

<!-- Product detail -->
<section class="py-5">
  <div class="container">
    <div class="row align-items-center g-5">

      <div class="col-lg-6">
        <div class="product-image-wrap">
          {% image product.imagePath, product.imageAlt or product.title, "(max-width: 768px) 100vw, 50vw" %}
        </div>
      </div>

      <div class="col-lg-6">
        <p class="mb-1" style="font-size: 0.75rem; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: #637554;">{{ categoryLabel }}{% if product.size %} &middot; {{ product.size }}{% endif %}</p>
        <h2 class="fw-bold mb-3">{{ product.title }}</h2>
        <p class="mb-3">{{ product.description }}</p>
        {% if product.highlight %}
        <p class="mb-3">{{ product.highlight }}</p>
        {% endif %}
        <p class="mb-4" style="font-size: 0.85rem; letter-spacing: 0.08em; text-transform: uppercase; color: #888;">
          Saintpaulia-stickling &middot; <strong style="color: var(--primary);">{{ price }} kr</strong>
        </p>
        <p class="text-muted mb-4" style="font-size: 0.9rem;">Hämtas hemma hos mig i Rogsta, Hudiksvall. Läs mina <a href="/skötselråd/">skötselråd</a> för att ge din stickling bästa start.</p>
        <a href="#beställ" class="btn primary-btn">Beställ stickling</a>
      </div>

    </div>
  </div>
</section>

{% if product.careNote %}
<!-- Care tip -->
<section class="py-4">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <div class="p-4" style="background: var(--beige-1); border: 1px solid rgba(0,0,0,0.06); border-radius: 0.75rem;">
          <h3 style="font-family: var(--font-family-header); font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 0.75rem;">Skötselråd för {{ product.title }}</h3>
          <p class="mb-0" style="color: #555; font-size: 0.95rem; line-height: 1.7;">{{ product.careNote }} Mer utförliga tips hittar du på sidan <a href="/skötselråd/">skötselråd för Saintpaulior</a>.</p>
        </div>
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- Order -->
<section id="beställ" class="contact-section">
  <div class="container">
    <div class="row">
      <div class="col-xl-8 mx-auto">
        {% set heading = "Intresserad av " + product.title + "?" %}
        {% set description = "Skicka ett meddelande så svarar jag så snart jag kan.<br>Allt hämtas hemma hos mig i Rogsta, Hudiksvall." %}
        {% include "contact-form.njk" %}
      </div>
    </div>
  </div>
</section>
