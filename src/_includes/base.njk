<!DOCTYPE html>
<html lang="sv">

<head>
  <!--====== Required meta tags ======-->
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <!--====== Title ======-->
  <title>{{ ((title or site.title) ~ ' - Drumla') | safe }}</title>

  <!--====== Meta tags ======-->
  <meta name="description" content="{{ description | safe or site.description }}" />
  <meta name="keywords" content="{{ keywords or 'Saintpaulior, afrikansk viol, afrikavioler, sticklingar, krukväxter, inomhusväxter, blommor, växter, hallon, Rogsta, Hudiksvall, köpa blommor Hudiksvall, växtförsäljning, ekologiska bär, odling' }}" />
  {% if robots %}<meta name="robots" content="{{ robots }}" />{% endif %}
  <meta name="author" content="{{ site.author }}" />
  <meta name="language" content="{{ site.language }}" />
  
  <!--====== Geo Location (Local SEO) ======-->
  <meta name="geo.region" content="SE-X" />
  <meta name="geo.placename" content="Hudiksvall, Gävleborgs län" />
  <meta name="geo.position" content="61.751296;17.121280" />
  
  <!--====== Open Graph ======-->
  <meta property="og:title" content="{{ title | safe or site.title }}" />
  <meta property="og:description" content="{{ ogDescription | safe or description or site.description }}" />
  <meta property="og:image" content="{{ site.url }}{{ ogImage or site.defaultImage }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:type" content="{{ ogType or 'website' }}" />
  <meta property="og:locale" content="{{ site.locale }}" />
  
  <!--====== Twitter Cards ======-->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title | safe or site.title }}" />
  <meta name="twitter:description" content="{{ ogDescription | safe or description or site.description }}" />
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage or site.defaultImage }}" />

  <!--====== Canonical URL ======-->
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <link rel="alternate" hreflang="sv" href="{{ site.url }}{{ page.url }}" />
  <link rel="me" href="https://www.instagram.com/drumla.se" />
  <link rel="me" href="https://www.facebook.com/people/Drumlase/61578983571719/" />
  {% if pagination %}
    {% if pagination.href.previous %}<link rel="prev" href="{{ site.url }}{{ pagination.href.previous }}" />{% endif %}
    {% if pagination.href.next %}<link rel="next" href="{{ site.url }}{{ pagination.href.next }}" />{% endif %}
  {% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link rel="stylesheet" href="/assets/css/bootstrap.css" />
  <link rel="stylesheet" href="{% asset '/assets/css/style.css' %}" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet">

  <!--====== Non-critical CSS (deferred) ======-->
  <link rel="stylesheet" href="/assets/css/lineicons.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/assets/css/tiny-slider.css" media="print" onload="this.media='all'" />
  <link rel="stylesheet" href="/assets/css/simple-lightbox.min.css" media="print" onload="this.media='all'" />

  {% block styles %}{% endblock %}

  {% if preloadImage %}<link rel="preload" as="image" imagesrcset="/assets/images/optimized/hero-image-flower-300w.webp 300w, /assets/images/optimized/hero-image-flower-600w.webp 600w, /assets/images/optimized/hero-image-flower-900w.webp 900w, /assets/images/optimized/hero-image-flower-1200w.webp 1200w" imagesizes="(max-width: 768px) 100vw, 50vw" type="image/webp">{% endif %}

  <link rel="icon" type="image/png" href="/assets/images/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
  <link rel="shortcut icon" href="/assets/images/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="Drumla" />
  <link rel="manifest" href="/assets/images/site.webmanifest" />
  <link rel="alternate" type="application/rss+xml" title="Drumla - Aktuellt" href="/feed.xml" />

  <!--====== Bootstrap css ======-->


  {% block jsonld %}{% endblock %}
</head>

<body>
  <!-- Header -->
  {% include "header.njk" %}

  <!-- Main content -->
  {{ content | safe }}

  <!-- Footer -->
  {% include "footer.njk" %}

  <!--====== js ======-->
  <script defer src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
  <script>
    // Only load on production environment.
    if (window.location.host !== 'drumla.se')
        window.goatcounter = {no_onload: true}
  </script>
  <script data-goatcounter="https://drumla.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
  <script defer src="/assets/js/bootstrap.bundle.min.js"></script>
  <script defer src="/assets/js/simple-lightbox.min.js"></script>
  <script defer src="{% asset '/assets/js/main.js' %}"></script>
  <script defer src="/assets/js/tiny-slider.min.js"></script>
  
  {% block scripts %}{% endblock %}
</body>

</html>
