---
layout: base.njk
ogType: "article"
---

{% block styles %}
<style>
  .post-content p:not(.lead) {
    margin-top: 1.5rem !important;
  }
  .event-info-box {
    background: var(--beige-1);
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 14px;
    padding: 1.5rem;
    margin-top: 1.5rem;
  }
  .event-info-heading {
    font-family: var(--font-family-header);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }
  .event-info-heading::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 1.15em;
    background: #637554;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .event-info-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .event-info-item:last-child {
    margin-bottom: 0;
  }
  .event-info-icon {
    width: 38px;
    height: 38px;
    background: linear-gradient(135deg, #7a8f68 0%, #526244 100%);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1rem;
    flex-shrink: 0;
  }
  .event-info-item strong {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #526244;
  }
  .event-info-item span {
    font-size: 0.95rem;
    color: #555;
  }
  .event-info-link {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
</style>
{% endblock %}

{% block jsonld %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.author }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.business.name }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/assets/images/favicon-96x96.png",
      "width": 96,
      "height": 96
    }
  },
  "datePublished": "{{ date | date('iso') }}",
  "dateModified": "{{ date | date('iso') }}",
  "url": "{{ site.url }}{{ page.url }}",
  "image": "{{ site.url }}/{{ image or 'assets/images/blog/forsagarden.jpg' }}",
  "inLanguage": "sv",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }{% if tags %},
  "keywords": {{ tags | dump | safe }}{% endif %}{% if location %},
  "locationCreated": {
    "@type": "Place",
    "name": "{{ location }}"
  }{% endif %}
}
</script>
{% if eventDate %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "startDate": "{{ eventDate | date('iso') }}",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": "{{ location }}",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "Gävleborgs län",
      "addressCountry": "SE"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Drumla",
    "url": "{{ site.url }}"
  },
  "image": "{{ site.url }}/{{ image or 'assets/images/blog/forsagarden.jpg' }}",
  "url": "{{ site.url }}{{ page.url }}"{% if eventLink %},
  "sameAs": "{{ eventLink }}"{% endif %}
}
</script>
{% endif %}
{% endblock %}

<!-- Start Post Hero Area -->
<section id="post-hero" class="header-area header-eight">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-12 col-md-12 col-12">
        <div class="header-content text-center">
          <h1>{{ title }}</h1>
          
          <div class="mt-3">
            <span>
              <i class="lni lni-clock"></i>
              Publicerad {{ date | date("D MMMM YYYY", "sv") }}
            </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- End Post Hero Area -->

{% set breadcrumbs = [
  { name: "Hem", url: "/", current: false },
  { name: "Aktuellt", url: "/aktuellt/", current: false },
  { name: title, url: page.url, current: true }
] %}
{% include "breadcrumbs.njk" %}

<!-- Post Image -->
<section class="post-image py-4 bg-light">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <div class="text-center">
          <div class="rounded-3 overflow-hidden">
            {% image image or "assets/images/blog/forsagarden.jpg", title, "(max-width: 768px) 100vw, 66vw" %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<!-- End Post Image -->

<!--====== POST CONTENT START ======-->
<section id="post-content" class="post-content-area about-five">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">
        <div class="post-content">
          <p class="lead">{{ description }}</p>
          
          {% if eventDate or location or eventTime %}
            <div class="event-info-box">
              <h3 class="event-info-heading">Praktisk information</h3>
              <div class="row g-3">
              {% if eventDate %}
                <div class="col-md-4">
                  <div class="event-info-item">
                    <div class="event-info-icon"><i class="lni lni-calendar"></i></div>
                    <div>
                      <strong>Datum</strong>
                      <span>{{ eventDate | date("D MMMM YYYY", "sv") }}</span>
                    </div>
                  </div>
                </div>
              {% endif %}
              {% if eventTime %}
                <div class="col-md-4">
                  <div class="event-info-item">
                    <div class="event-info-icon"><i class="lni lni-timer"></i></div>
                    <div>
                      <strong>Tid</strong>
                      <span>{{ eventTime }}</span>
                    </div>
                  </div>
                </div>
              {% endif %}
              {% if location %}
                <div class="col-md-4">
                  <div class="event-info-item">
                    <div class="event-info-icon"><i class="lni lni-map-marker"></i></div>
                    <div>
                      <strong>Plats</strong>
                      <span>{{ location }}</span>
                    </div>
                  </div>
                </div>
              {% endif %}
              </div>
              {% if eventLink %}
                <div class="event-info-link">
                  <a href="{{ eventLink }}" target="_blank" rel="noopener" class="text-decoration-none" style="color: #526244; font-weight: 600;">
                    <i class="lni lni-facebook-original me-1"></i>
                    Gå till evenemanget
                  </a>
                </div>
              {% endif %}
            </div>
          {% endif %}
          
          {{ content | safe }}
          
          <!-- Navigation to other posts -->
          <nav class="mt-5 pt-4 border-top">
            <div class="row">
              <div class="col-md-6">
                {% set prevPost = collections.blog | getPreviousCollectionItem(page) %}
                {% if prevPost %}
                  <a href="{{ prevPost.url }}" class="btn primary-btn text-start">
                    <i class="lni lni-arrow-left"></i>
                    Föregående
                  </a>
                {% endif %}
              </div>
              <div class="col-md-6 text-end">
                {% set nextPost = collections.blog | getNextCollectionItem(page) %}
                {% if nextPost %}
                  <a href="{{ nextPost.url }}" class="btn primary-btn">
                    Nästa
                    <i class="lni lni-arrow-right"></i>
                  </a>
                {% endif %}
              </div>
            </div>
          </nav>
        </div>
      </div>
    </div>
  </div>
  <!-- container -->
</section>
<!--====== POST CONTENT ENDS ======-->
